<labwc_config>
  <keyboard>
    <default />

    <!-- program shortcuts -->
    <keybind key="C-S-s">
      <action name="Execute" command="kitty" />
    </keybind>

    <keybind key="W-e">
      <action name="Execute" command="thunar" />
    </keybind>

    <keybind key="A-s">
      <action name="Execute" command="rofi -show-icons -show drun" />
    </keybind>

    <!-- Audio Control -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute" command="wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 10%+"/>
    </keybind>

    <keybind key="XF86AudioLowerVolume">
      <action name="Execute" command="wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 10%-"/>
    </keybind>

    <keybind key="XF86AudioMute">
      <action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"/>
    </keybind>

    <keybind key="XF86AudioMicMute">
      <action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"/>
    </keybind>

    <!-- Brightness Contr-->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute" command="brightnessctl set +10%"/>
    </keybind>

    <keybind key="XF86MonBrightnessDown">
      <action name="Execute" command="brightnessctl set 10%-"/>
    </keybind>

    <!-- Screenshot Capabilities-->
    <keybind key="W-S-s">
      <action name="Execute" command="~/.config/labwc/screenshot.sh"/>
    </keybind>


    <!-- Toggle labwc keybinds-->
    <keybind key="A-F12">
      <action name="ToggleKeybinds" />
    </keybind>

  </keyboard>

  <libinput>
    <device category="default">
      <naturalScroll>yes</naturalScroll>
    </device>
  </libinput>

  <theme>
    <name>Numix-Clone</name>
    <cornerRadius>8</cornerRadius>
  </theme>



</labwc_config>
