{
  "height": 42,
  "layer": "top",
  "position": "top",
  "include": [
    "~/.config/waybar/wuntu-noble-waybar/modules/taskbar.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/audio.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/battery.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/clock.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/network.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/bluetooth.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/network.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/audio-bluetooth.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/backlight.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/power_menu.jsonc",
    "~/.config/waybar/wuntu-noble-waybar/modules/notification.jsonc"
  ],
  "modules-left": ["wlr/taskbar"],
  "modules-right": [
    "group/audio-bluetooth",
    "backlight",
    "network",
    "battery",
    "clock",
    "custom/notification",
    "custom/power",
  ],
  "reload_style_on_change": true,
}
